# PostgreSQL
POSTGRES_DB=virtual_ai_patient
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# For local dev outside Docker. In Docker, docker-compose overrides this.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/virtual_ai_patient

# Auth
SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_KEY

# Admin seed (created on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Frontend (used when constructing password-reset links)
FRONTEND_URL=http://localhost:8080

# SMTP (optional — leave blank to log reset links instead of emailing them)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Bot
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_TOKEN
BACKEND_BASE_URL=http://localhost:8000
BACKEND_USERNAME=admin
BACKEND_PASSWORD=password
